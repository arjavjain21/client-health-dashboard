{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/unmatched/layout,_N_T_/unmatched/page,_N_T_/unmatched"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/unmatched/__PAGE__",
    "/unmatched",
    "/_index",
    "/_head"
  ]
}